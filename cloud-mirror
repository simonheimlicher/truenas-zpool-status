#!/usr/bin/env python3
"""Standalone wrapper for cloud-mirror.

Resolves its own location to find the cloud_mirror package,
adds parent directory to sys.path, and invokes main().

This wrapper supports:
- Direct execution: ./cloud-mirror [args]
- Symlinked execution: /usr/local/bin/cloud-mirror → /path/to/cloud-mirror
- Invocation from any working directory
"""
import sys
from pathlib import Path

# Resolve wrapper location (handles symlinks)
wrapper_path = Path(__file__).resolve()
package_parent = wrapper_path.parent
package_dir = package_parent / "cloud_mirror"

# Verify package exists
if not package_dir.exists():
    print(
        f"Error: cloud_mirror package not found at {package_dir}",
        file=sys.stderr,
    )
    sys.exit(1)

# Add parent to sys.path for import
if str(package_parent) not in sys.path:
    sys.path.insert(0, str(package_parent))

# Import and invoke main
from cloud_mirror.main import main

sys.exit(main())
