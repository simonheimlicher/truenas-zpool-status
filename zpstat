#!/usr/bin/env python3
"""Standalone wrapper for zpool-status.

Resolves its own location to find the zpool_status package,
adds parent directory to sys.path, and invokes main().

This wrapper supports:
- Direct execution: ./zpstat [args]
- Symlinked execution: /usr/local/bin/zpstat → /path/to/zpstat
- Invocation from any working directory

Deployment on TrueNAS:
  git clone <repo> /mnt/system/admin/zpool-status
  ln -s /mnt/system/admin/zpool-status/zpstat /usr/local/bin/zpstat
"""
import sys
from pathlib import Path

# Resolve wrapper location (handles symlinks)
wrapper_path = Path(__file__).resolve()
package_parent = wrapper_path.parent
package_dir = package_parent / "zpool_status"

# Verify package exists
if not package_dir.exists():
    print(
        f"Error: zpool_status package not found at {package_dir}",
        file=sys.stderr,
    )
    sys.exit(1)

# Add parent to sys.path for import
if str(package_parent) not in sys.path:
    sys.path.insert(0, str(package_parent))

from zpool_status.main import main

main()
